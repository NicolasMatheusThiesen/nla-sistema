# ============================================================
# FRONTEND — Variáveis de Ambiente
# Copie este arquivo como .env.local e preencha com seus dados.
# NUNCA suba o arquivo .env.local para o GitHub.
# ============================================================

# ─── Supabase ─────────────────────────────────────────────────
# Encontre em: supabase.com → Seu Projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ─── URL da API ───────────────────────────────────────────────
# Em desenvolvimento: http://localhost:3001
# Em produção: https://nla-api.onrender.com (sua URL do Render)
NEXT_PUBLIC_API_URL=http://localhost:3001
